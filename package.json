{
  "name": "linkedin-job-scraper",
  "version": "1.0.0",
  "description": "AI-powered LinkedIn job scraper with modern glassmorphism UI",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest",
    "lint": "eslint .",
    "setup": "npm install && echo 'Setup complete! Please configure your .env file.'",
    "scrape": "node -e \"console.log('Use the web interface to scrape jobs')\"",
    "clean": "rm -rf node_modules package-lock.json && npm install"
  },
  "keywords": [
    "linkedin",
    "job-scraper",
    "playwright",
    "ai",
    "gemma",
    "job-search",
    "web-scraping",
    "glassmorphism",
    "nodejs"
  ],
  "author": "LinkedIn Job Scraper Team",
  "license": "MIT",
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "playwright": "^1.40.0",
    "cheerio": "^1.0.0-rc.12",
    "axios": "^1.6.0",
    "helmet": "^7.1.0",
    "compression": "^1.7.4",
    "morgan": "^1.10.0",
    "express-rate-limit": "^7.1.0",
    "express-validator": "^7.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "jest": "^29.7.0",
    "eslint": "^8.52.0",
    "prettier": "^3.0.3",
    "@types/node": "^20.8.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/linkedin-job-scraper.git"
  },
  "bugs": {
    "url": "https://github.com/yourusername/linkedin-job-scraper/issues"
  },
  "homepage": "https://github.com/yourusername/linkedin-job-scraper#readme",
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "**/*.js",
      "!node_modules/**",
      "!coverage/**",
      "!public/**"
    ]
  },
  "eslintConfig": {
    "env": {
      "node": true,
      "es2021": true
    },
    "extends": "eslint:recommended",
    "parserOptions": {
      "ecmaVersion": 12,
      "sourceType": "module"
    },
    "rules": {
      "no-console": "warn",
      "no-unused-vars": "error",
      "prefer-const": "error"
    }
  },
  "nodemonConfig": {
    "watch": [
      "server.js",
      "routes/",
      "scraper/",
      "ai/"
    ],
    "ext": "js,json",
    "ignore": [
      "public/",
      "node_modules/",
      "*.test.js"
    ],
    "env": {
      "NODE_ENV": "development"
    }
  }
}